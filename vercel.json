{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://fi4.bot-hosting.net:22135/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "http://fi4.bot-hosting.net:22135/uploads/$1"
    },
    {
      "source": "/media/(.*)",
      "destination": "http://fi4.bot-hosting.net:22135/media/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "http://fi4.bot-hosting.net:22135/socket.io/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}