{
  "version": 2,
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://fi4.bot-hosting.net:22135/api/$1"
    },
    {
      "source": "/share/(.*)",
      "destination": "http://fi4.bot-hosting.net:22135/share/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "http://fi4.bot-hosting.net:22135/uploads/$1"
    },
    {
      "source": "/media/(.*)",
      "destination": "http://fi4.bot-hosting.net:22135/media/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "http://fi4.bot-hosting.net:22135/images/$1"
    },
    {
      "source": "/payments-images/(.*)",
      "destination": "http://fi4.bot-hosting.net:22135/payments-images/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "http://fi4.bot-hosting.net:22135/socket.io/$1"
    },
    {
      "source": "/((?!api/|uploads/|media/|images/|payments-images/|socket.io/|share/|.*\\.(?:png|jpg|jpeg|gif|ico|json|svg|css|js|woff|woff2|webmanifest)).*)",
      "destination": "/index.html"
    }
  ]
}
